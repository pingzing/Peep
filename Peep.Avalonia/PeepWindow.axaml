<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="using:Peep.Avalonia"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="450"
  x:Class="Peep.Avalonia.PeepWindow"
  Title="Peep"
  Background="Transparent"
  Height="160"
  Width="156"
  CanResize="False"
  Topmost="True"
  ShowInTaskbar="False"
  TransparencyLevelHint="Transparent"
  TransparencyBackgroundFallback="Transparent"
  ShowActivated="False"
  WindowDecorations="None"
>
  <Grid IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center">
    <local:GifAnimatorControl
      Name="ImageElement"
      IsHitTestVisible="false"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Opacity="1"
      RepeatBehavior="None"
    >
      <local:GifAnimatorControl.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.150" />
        </Transitions>
      </local:GifAnimatorControl.Transitions>
    </local:GifAnimatorControl>
  </Grid>
</Window>
